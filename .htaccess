# SPA Fallback - redirect all non-file requests to index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 靜態資源直接服務
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 其他路徑全部 fallback 到 index.html
  RewriteRule ^ index.html [L]
</IfModule>
